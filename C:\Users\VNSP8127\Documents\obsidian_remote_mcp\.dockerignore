# .dockerignore - Exclude files from Docker context

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Build outputs
dist/
build/
.next/
out/

# Logs
logs/
*.log

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Git
.git/
.gitignore

# Docker
Dockerfile*
docker-compose*.yml
.dockerignore

# Documentation
README.md
*.md

# Test files
test/
tests/
__tests__/
coverage/

# Temporary files
tmp/
temp/
*.tmp

# Cache directories
.cache/
.parcel-cache/

# Database files
*.sqlite
*.db

# Obsidian vault (handled via volume mounts)
obsidian/.obsidian/workspace
obsidian/.obsidian/workspace.json